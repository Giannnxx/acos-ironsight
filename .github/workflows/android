name: Android Signed Release

on:
  push:
    branches: ["main"]

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout sources
        uses: actions/checkout@v5
        with:
          fetch-depth: 0
          submodules: recursive

      - name: Setup Java
        uses: actions/setup-java@v4
        with:
          java-version: 17
          distribution: temurin
          cache: gradle

      - name: Make gradlew executable
        run: chmod +x gradlew
        working-directory: android

      - name: Decode Keystore
        working-directory: android
        run: |
          echo "${{ secrets.KEYSTORE_FILE }}" | base64 --decode > release.jks

      - name: Build Signed Release APK
        working-directory: android
        env:
          KEYSTORE_FILE_PATH: release.jks
          KEYSTORE_PASSWORD: ${{ secrets.KEYSTORE_PASSWORD }}
          KEY_ALIAS: ${{ secrets.KEY_ALIAS }}
          KEY_PASSWORD: ${{ secrets.KEY_PASSWORD }}
        run: |
          ./gradlew assembleRelease

      - name: Locate APK
        working-directory: android
        run: |
          echo "APK_PATH=$(find app/build/outputs/apk -name '*.apk' | head -n 1)" >> $GITHUB_ENV

      - name: Copy APK
        working-directory: android
        run: |
          cp $APK_PATH CS16Client-release.apk

      - name: Upload Artifact
        uses: actions/upload-artifact@v4
        with:
          name: Signed-APK
          path: android/CS16Client-release.apk

      - name: Create GitHub Release
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          TAG="v$(date +'%Y.%m.%d-%H%M')"

          gh release create "$TAG" \
            --title "Android Release $TAG" \
            --latest \
            android/CS16Client-release.apk
